	number = {4},
	pages = {773--784},
	title = {Were {{Bush Tax Cut}} and {{Supporters}} ``{{Simply Ignorant}}?'' {{A Second Look}} at {{Conservatives}} and {{Liberals}} in ``{{Homer Gets}} a {{Tax Cute}}''},
	volume = {5},
