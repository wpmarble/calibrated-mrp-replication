	pmid = {1271224},
	title = {Personal Space Invasions in the Lavatory: Suggestive Evidence for Arousal.},
	volume = {33},
	year = {1976},
	bdsk-url-1 = {https://doi.org/10.1037/0022-3514.33.5.541}}

