@article{Gilens2005,
	abstract = {By allowing voters to choose among candidates with competing policy\textbackslash norientations and by providing incentives for incumbents to shape\textbackslash npolicy in the direction the public desires, elections are thought\textbackslash nto provide the foundation that links government policy to the preferences\textbackslash nof the governed. In this article I examine the extent to which the\textbackslash npreference/policy link is biased toward the preferences of high-income\textbackslash nAmericans. Using an original data set of almost two thousand survey\textbackslash nquestions on proposed policy changes between 1981 and 2002, I find\textbackslash na moderately strong relationship between what the public wants and\textbackslash nwhat the government does, albeit with a strong bias toward the status\textbackslash nquo. But I also find that when Americans with different income levels\textbackslash ndiffer in their policy preferences, actual policy outcomes strongly\textbackslash nreflect the preferences of the most affluent but bear virtually no\textbackslash nrelationship to the preferences of poor or middle-income Americans.\textbackslash nThe vast discrepancy I find in government responsiveness to citizens\textbackslash nwith different incomes stands in stark contrast to the ideal of political\textbackslash nequality that Americans hold dear. Although perfect political equality\textbackslash nis an unrealistic goal, representational biases of this magnitude\textbackslash ncall into question the very democratic character of our society.},
	author = {Gilens, Martin},
	doi = {10.1093/poq/nfi058},
	file = {/Users/wpmarble/Zotero/storage/JZ5CZV6A/2005-Inequality_and_Democratic_Responsiveness.pdf},
