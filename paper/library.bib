@techreport{Canen,
	abstract = {In this paper, we present and structurally estimate a model of en- dogenous network formation and legislative activity of politicians. Employ- ing data on social and legislative effort of members of the 105th-110th U.S. Congresses (1997-2009), we find that there are substantial complementarities between the efforts of politicians, both within and across parties. We report significant differences in preferences between political parties. We also show that, although partisanship is a significant driver of socializing in Congress, the empirical evidence on social interactions paints a less polarized picture of the informal connections of members of Congress than typically emerges from roll call evidence. Finally, we show that this formulation is useful for developing rel- evant counterfactuals, including some pertinent to the congressional emergency response to the 2008-09 financial crisis. Date:},
