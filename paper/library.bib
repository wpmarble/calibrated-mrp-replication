@article{Alesina2013,
	abstract = {The study examines the historical origins of existing cross-cultural differ-\textbackslash nences in beliefs and values regarding the appropriate role of women in society.\textbackslash nWe test the hypothesis that traditional agricultural practices influenced the\textbackslash nhistorical gender division of labor and the evolution of gender norms. We find\textbackslash nthat, consistent with existing hypotheses, the descendants of societies that trad-\textbackslash nitionally practiced plough agriculture today have less equal gender norms, mea-\textbackslash nsured using reported gender-role attitudes and female participation in the\textbackslash nworkplace, politics, and entrepreneurial activities. Our results hold looking\textbackslash nacross countries, across districts within countries, and across ethnicities\textbackslash nwithin districts. To test for the importance of cultural persistence, we examine\textbackslash nthe children of immigrants living in Europe and the United States. We find that\textbackslash neven among these individuals, all born and raised in the same country, those\textbackslash nwith a heritage of traditional plough use exhibit less equal beliefs about gender\textbackslash nroles today},
