	issn = {15723127},
	journal = {Statistical Methodology},
	keywords = {bayes,Ecological fallacy,ecological inference,Ecological inference,Ecological regression,econometrics,Hierarchical models,Identification,methods,survey,Survey sampling},
	number = {3},
