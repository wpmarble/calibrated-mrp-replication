@article{Eicher2012,
	abstract = {The literature on Foreign Direct Investment (FDI) determinants is remarkably diverse in terms of competing theories and empirical results. We utilize Bayesian Model Averaging (BMA) to resolve the model uncertainty that surrounds the validity of the competing FDI theories. Since the structure of existing FDI data is well known to induce selection bias, we extend BMA theory to HeckitBMA in order to address model uncertainty in the presence of selection bias. We show that more than half of the previously suggested FDI determinants are not robust and highlight theories that do receive robust support from the data. Our selection approach allows us to identify the determinants of the margins of FDI (intensive and extensive), which are shown to differ profoundly. Our results suggest a new emphasis in FDI theories that explicitly identify the dynamics of the intensive and extensive FDI margins. \textcopyright{} 2012 Elsevier Inc.},
