@article{Kernell2009,
	abstract = {Correctly measuring district preferences is crucial for empirical\textbackslash nresearch on legislative responsiveness and voting behavior. This\textbackslash narticle argues that the common practice of using presidential vote\textbackslash nshares to measure congressional district ideology systematically\textbackslash nproduces incorrect estimates. I propose an alternative method that\textbackslash nemploys multiple election returns to estimate voters' ideological\textbackslash ndistributions within districts. I develop two estimation procedures--a\textbackslash nleast squared error model and a Bayesian model--and test each with\textbackslash nsimulations and empirical applications. The models are shown to outperform\textbackslash nvote shares, and they are validated with direct measures of voter\textbackslash nideology and out-of-sample election predictions. Beyond estimating\textbackslash ndistrict ideology, these models provide valuable information on constituency\textbackslash nheterogeneity--an important, but often immeasurable, quantity for\textbackslash nresearch on representatives' strategic behavior.},
