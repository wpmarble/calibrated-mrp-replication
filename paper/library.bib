@book{Kenski2010,
	abstract = {Barack Obama's stunning victory in the 2008 presidential election will go down as one of the more pivotal in American history. Given America's legacy of racism, how could a relatively untested first-term senator with an African father defeat some of the giants of American politics? In The Obama Victory, Kate Kenski, Bruce Hardy, and Kathleen Hall Jamieson draw upon the best voter data available, The National Annenberg Election Survey, as well as interviews with key advisors to each campaign, to illuminate how media, money, and messages shaped the 2008 election. They explain how both sides worked the media to reinforce or combat images of McCain as too old and Obama as not ready; how Obama used a very effective rough-and-tumble radio and cable campaign that was largely unnoticed by the mainstream media; how the Vice Presidential nominees impacted the campaign; how McCain's age and Obama's race affected the final vote, and much more. Briskly written and filled with surprising insights, The Obama Victory goes beyond opinion to offer the most authoritative account available of precisely how and why Obama won the presidency.},
	author = {Kenski, Kate and Hardy, Bruce W. and Jamieson, Kathleen Hall},
	isbn = {0-19-977985-6},
	keywords = {campaigns,export},
	publisher = {{Oxford University Press}},
	title = {The {{Obama Victory}}: {{How Media}}, {{Money}}, and {{Message Shaped}} the 2008 {{Election}}},
	urldate = {2015-02-25},
	year = {2010}}

@article{Kenworthy2005,
	abstract = {We use data from the Luxembourg Income Study to examine household\textbackslash nmarket inequality, redistribution, and the relationship between market\textbackslash ninequality and redistribution in affluent OECD countries in the 1980s\textbackslash nand 1990s. We observe sizeable increases in market household inequality\textbackslash nin most countries. This development appears to have been driven largely,\textbackslash nthough not exclusively, by changes in employment: in countries with\textbackslash nbetter employment performance, low-earning households benefited relative\textbackslash nto high-earning ones; in nations with poor employment performance,\textbackslash nlow-earning households fared worse. In contrast to widespread rhetoric\textbackslash nabout the decline of the welfare state, redistribution increased\textbackslash nin most countries during this period, as existing social-welfare\textbackslash nprograms compensated for the rise in market inequality. They did\textbackslash nso in proportion to the degree of increase in inequality, producing\textbackslash na very strong positive association between changes in market inequality\textbackslash nand changes in redistribution. We discuss the relevance of median-voter\textbackslash ntheory and power resources theory for understanding differences across\textbackslash ncountries and changes over time in the extent of compensatory redistribution.},
	author = {Kenworthy, Lane and Pontusson, Jonas},
	doi = {10.1017/S1537592705050292},
	file = {/Users/wpmarble/Zotero/storage/AFGUKTBK/2005-Rising_Inequality_and_the_Politics_of_Redistribution_in_Affluent_Countries.pdf},
	isbn = {15375927},
