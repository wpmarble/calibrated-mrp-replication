@article{Baldwin2010,
	abstract = {arguments about how ethnic diversity affects governance typically posit that groups differ from each other in substantively important ways and that these differences make effective governance more difficult. But existing cross-national empirical tests typically use measures of ethnolinguistic fractionalization (ELF) that have no information about substantive differences between groups. This ar- A ticle examines two important ways that groups differ from each other\textemdash culturally and economically\textemdash and assesses how such differences affect public goods provision. Across 46 countries, the analysis compares existing measures of cultural differences with a new measure that captures economic differences between groups: between-group inequality (BGI). We show that ELF, cultural fractionalization (CF), and BGI measure different things, and that the choice between them has an important impact on our understanding of which countries are most ethnically diverse. Furthermore, empirical tests reveal that BGI has a large, robust, and negative relationship with public goods provision, whereas CF, ELF, and overall inequality do},
