@article{Shayo2009,
	abstract = {This article develops a model for analyzing social identity and applies\textbackslash nit to the political economy of income redistribution, focusing on\textbackslash nclass and national identities. The model attempts to distill major\textbackslash nfindings in social psychology into a parsimonious statement of what\textbackslash nit means to identify with a group and what factors determine the\textbackslash ngroups with whom people identify. It then proposes an equilibrium\textbackslash nconcept where both identities and behavior are endogenously determined.\textbackslash nApplying this model to redistribution helps explain three empirical\textbackslash npatterns in modern democracies. First, national identification is\textbackslash nmore common among the poor than among the rich. Second, national\textbackslash nidentification tends to reduce support for redistribution. Third,\textbackslash nacross democracies there is a strong negative relationship between\textbackslash nthe prevalence of national identification and the level of redistribution.\textbackslash nThe model further points to national eminence, national threats,\textbackslash nand diversity within the lower class as factors that can reduce redistribution.},
