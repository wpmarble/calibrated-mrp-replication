@article{Morgan2021,
	abstract = {The General Social Survey (GSS) shows that many self-identified white adults continue to hold racial attitudes that can be regarded, collectively, as a persistent social problem. Similar to findings from the analysis of electoral surveys, the GSS also shows that these racial attitudes have more strongly predicted political behavior since 2012. However, and in contrast to group-identity interpretations of these patterns, the increase in predictive power since 2012 is attributable to a positive development: above and beyond the effects of cohort replacement, support for compensatory interventions to address black-white inequalities has increased substantially, while prejudice and bigotry have decreased slightly. Because these changes have been larger on the political left than on the political right, the attitudes have gained in overall predictive power.},
