@article{Barabas2010,
	abstract = {ABSTRACT Researchers use survey experiments to establish causal effects\textbackslash nin descriptively representative samples, but concerns remain regarding\textbackslash nthe strength of the stimuli and the lack of realism in experimental\textbackslash nsettings. We explore these issues by comparing three national survey\textbackslash nexperiments on Medicare and immigration with contemporaneous natural\textbackslash nexperiments on the same topics. The survey experiments reveal that\textbackslash nproviding information increases political knowledge and alters attitudes.\textbackslash nIn contrast, two real-world government announcements had no discernable\textbackslash neffects, except among people who were exposed to the same facts publicized\textbackslash nin the mass media. Even among this exposed subsample, treatment effects\textbackslash nwere smaller and sometimes pointed in the opposite direction. Methodologically,\textbackslash nour results suggest the need for caution when extrapolating from\textbackslash nsurvey experiments. Substantively, we find that many citizens are\textbackslash nable to recall factual information appearing in the news but may\textbackslash nnot adjust their beliefs and opinions in response to this information.\textbackslash n},
