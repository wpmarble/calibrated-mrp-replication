@techreport{Sahn2019,
	abstract = {High housing prices drive inequality, reduce growth, and increase racial segregation. Scholars have identified laws restricting the use of land, particularly for dense multi-family housing, as the primary cause of housing unaffordability. Why do municipal governments adopt these laws? I argue that in response to the Great Migration of African-Americans to non-Southern cities, municipal governments enacted zoning policies to exclude the poor in response to white residents preferences. Using original data on municipal zoning laws and leveraging exogenous factors for black migration from 1940 to 1970, I show that cities that receive more migration 1) have more exclusionary zoning, 2) produce fewer new units of multi-family housing, and 3) have more unaffordable housing. I show that white racial attitudes became more conservative in cities that receive more of the Great Migration and argue that these preferences drove changes in zoning laws. These findings both explain the origins of exclusionary zoning and the consequences of these policies for housing affordability. {${_\ast}$}Ph.D.},
	author = {Sahn, Alexander},
	file = {/Users/wpmarble/Zotero/storage/LTA9IC5V/Sahn - 2019 - Why is Housing Unaffordable The Great Migration's Effect on Exclusionary Zoning.pdf},
