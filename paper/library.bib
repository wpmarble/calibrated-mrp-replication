@article{Mackie1996,
	abstract = {Female genital mutilation in Africa persists despite modernization,\textbackslash npublic education, and legal prohibition. Female footbinding in China\textbackslash nlasted for 1,000 years but ended in a single generation. I show that\textbackslash neach practice is a self-enforcing convention, in Schelling's (1960)\textbackslash nsense, maintained by interdependent expectations on the marriage\textbackslash nmarket. Each practice originated under conditions of extreme resource\textbackslash npolygyny as a means of enforcing the imperial male's exclusive sexual\textbackslash naccess to his female consorts. Extreme polygyny also caused a competitive\textbackslash nupward flow of women and a downward flow of conjugal practices, accounting\textbackslash nfor diffusion of the practices. A Schelling coordination diagram\textbackslash nexplains how the three methods of the Chinese campaign to abolish\textbackslash nfootbinding succeeded in bringing it to a quick end. The pivotal\textbackslash ninnovation was to form associations of parents who pledged not to\textbackslash nfootbind their daughters nor let their sons marry footbound women.\textbackslash nThe "convention" hypothesis predicts that promotion of such pledge\textbackslash nassociations would help bring female genital mutilation to an end.},
