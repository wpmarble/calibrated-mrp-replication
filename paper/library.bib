	keywords = {families have become more,income inequality,income segregation,neighborhood segregation,school district,school district fragmentation,segregated by,segregation,sociology},
	title = {Inequality in {{Children}}'s {{Contexts}}: {{The Economic Segregation}} of {{Households}} with and {{Without Children}}},
	year = {2016},
	bdsk-url-1 = {https://doi.org/10.1177/0003122416642430}}

@techreport{Owens2018,
	abstract = {We study the urban structure of the City of Detroit. Following several decades of decline, the city's current urban structure is clearly not optimal for its size, with a business district immediately surrounded by a ring of largely vacant neighborhoods. We propose a model with residential externalities that features multiple equilibria at the neighborhood level. In particular, developing a residential area requires the coordination of developers and residents, without which it may remain vacant even if its fundamentals are sound. We embed this mechanism in a quantitative spatial economics model and use it to rationalize current city allocations. We then use the model to evaluate existing strategic visions to revitalize Detroit, and to design alternative plans that rely on `development guarantees' to yield better outcomes. The widespread e\textcurrency ects of these policies underscore the importance of using a general equilibrium framework to evaluate policy proposals. 1},
