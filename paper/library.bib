@article{Xu2016,
	abstract = {Difference-in-differences (DID) is commonly used for causal inference in time-series cross-sectional data. It requires the assumption that the average outcomes of treated and control units would have followed parallel paths in the absence of treatment. In this paper, we propose a method that not only relaxes this osten-violated assumption, but also unifies the synthetic control method (Abadie, Diamond, and Hainmueller 2010) with linear fixed effects models under a simple framework, of which DID is a special case. It imputes counterfactuals for each treated unit using control group information based on a linear interactive fixed effects model that incorporates unit-specific intercepts interacted with time-varying coefficients. This method has several advantages. First, it allows the treatment to be correlated with unobserved unit and time heterogeneities under reasonable modeling assumptions. Second, it generalizes the synthetic control method to the case of multiple treated units and variable treatment periods, and improves efficiency and interpretability. Third, with a built-in cross-validation procedure, it avoids specification searches and thus is easy to implement. An empirical example of Election Day Registration and voter turnout in the United States is provided.},
	author = {Xu, Yiqing},
	doi = {10.1017/pan.2016.2},
	file = {/Users/wpmarble/Zotero/storage/ULNBWIUU/Xu - generalized_synthetic_control.pdf},
	issn = {14764989},
	journal = {Political Analysis},
	keywords = {causal inference,diff-in-diff,difference-in-differences,factor analysis,interactive fixed effects,methods,synthetic con-,synthetic control methods,trol method,tscs data},
	number = {1},
	pages = {57--76},
	title = {Generalized {{Synthetic Control Method}}: {{Causal Inference}} with {{Interactive Fixed Effects Models}}},
	volume = {25},
	year = {2017},
	bdsk-url-1 = {https://doi.org/10.1017/pan.2016.2}}

@article{Yackee2009,
	abstract = {Despite paying a great deal of attention to the effects of divided\textbackslash ngovernment on legislative outputs, scholars of American politics\textbackslash nhave surprisingly ignored the potential impact of divided government\textbackslash non bureaucratic regulatory outputs. In this article we argue that\textbackslash ndivided government should reduce the volume of federal agency rulemaking.\textbackslash nWe test this hypothesis against a data set covering 21,000 rules\textbackslash nfrom 1983 to 2005. Our study is one of the first to analyze the determinants\textbackslash nof federal bureaucratic rulemaking activity across such a long period\textbackslash nof time. Our results demonstrate that during periods of divided government,\textbackslash nagencies issue fewer rules and fewer substantively significant rules\textbackslash nthan they do during periods of unified government. These findings\textbackslash nsuggest that divided government impedes agency rulemaking.},
