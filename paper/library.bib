@article{Reardon2004,
	abstract = {The measurement of residential segregation patterns and trends has been limited by a reliance on segregation measures that do not appropriately take into account the spatial patterning of population distributions. In this paper we define a general approach to measuring spatial segregation among multiple population groups. This general approach allows researchers to specify any theoretically based definition of spatial proximity desired in computing segregation measures. Based on this general approach, we develop a general spatial exposure/isolation index ({\~P}*), and a set of general multigroup spatial evenness/clustering indices: a spatial information theory index ({\~H}), a spatial relative diversity index ({\~R}), and a spatial dissimilarity index ({\~D}). We review these and previously proposed spatial segregation indices against a set of eight desirable properties of spatial segregation indices. We conclude that the spatial exposure/isolation index {\~P}*\textemdash which can be interpreted as a measure of the average composition of individuals' local spatial environments\textemdash and the spatial information theory index {\~H}\textemdash which can be interpreted as a measure of the variation in the diversity of the local spatial environments of each individual\textemdash are the most conceptually and mathematically satisfactory of the proposed spatial indices.},
	author = {Reardon, Sean F and Sullivan, David O},
	doi = {10.1111/j.0081-1750.2004.00150.x},
	file = {/Users/wpmarble/Zotero/storage/T4U2HLN6/2004-Measure_of_Spatial_Segregation.pdf},
