	year = {2015},
	bdsk-url-1 = {https://doi.org/10.1073/pnas.1502615112}}

@article{Fowler2015a,
	abstract = {Elections matter \textendash{} even more than previously thought. Democratic and Republican legislators diverge significantly in the way that they represent the exact same district at the exact same time. Moreover, a single election result influences many more elections downstream. As a result of these two phenomena, elections hold significant long-term consequences for representation and public policy. Combining electoral and legislative roll call data in a dynamic regression-discontinuity design, we find that a ``coin-flip'' election in a moderate district will significantly influence the way in which an electorate is represented for more than a decade. The effects of one election persist for approximately 16 years in Congress, 12 years in state legislatures, and 20 years in the case of open seat races. The findings support a new model of divergent and persistent representation in American legislatures whereby representational inertia poses a challenge to voter welfare and democratic representation.},
	author = {Fowler, Anthony and Hall, Andrew B.},
