	doi = {10.1017/S0003055418000035},
	file = {/Users/wpmarble/Zotero/storage/QEZ2I7S7/Hankinson - 2018 - When Do Renters Behave Like Homeowners High Rent, Price Anxiety, and NIMBYism(2).pdf},
