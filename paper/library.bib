	issn = {0003-0554},
	journal = {American Political Science Review},
	keywords = {comparative politics,immigration,survey},
	number = {1},
	pages = {61--84},
	title = {Attitudes {{Toward Highly Skilled}} and {{Low-Skilled Immigration}}: {{Evidence}} from a {{Survey Experiment}}},
	volume = {104},
