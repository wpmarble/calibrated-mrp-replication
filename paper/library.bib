@incollection{Laitin2002,
	abstract = {``Comparative politics is a distinct subdiscipline of political science, defined by substantively and methodological criteria. Substantively: CP seeks to account for the variation in outcomes among political units on consequential questions that have been posed in political theory. Methodologically: In the past CP differentiated from statistical and case-study, and it emphasized through the use of strategic controls the isolation of key variables. Today CP tripartite methodology: 1. 1. Statistics: Cross-sectional or diachronic data used to find statistical regularities across large numbers of similar units. 2. 2. Formalization: F. modeling provides as internally consistent logic that accounts for the stipulated relationships among abstract variables, in order to assure that causal stories are coherent and non contradictory. 3. 3. Narrative: Examination of real cases to trace historically and to theorize empirically the values on IV onto values on DV. ``If statistics addresses questions of propensities, narratives address questions of process'' (631) ``The identification of competing approaches or alternative explanatory variables is, in my judgment, the wrong way to go in developing a discipline'' (633)},
	address = {{New York}},
