	file = {/Users/wpmarble/Zotero/storage/GZGQGCXA/2011-An_Examination_of_Efforts_to_Encourage_the_Incidence_of_Early_In-Person_Voting_in_Georgia_2008.pdf},
	isbn = {1533-1296},
	journal = {Election Law Journal},
	number = {2},
