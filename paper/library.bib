@techreport{Hankinson2015,
	abstract = {Research has linked the disproportionate inflation of housing costs in the top decile of American cities to regulations limiting the elasticity of the local housing supply, particularly in cities with large liberal vote shares. Theories of this ideological link blame either increased opposition to new housing, increased spatial sensitivity to the siting of new housing (NIMBYism), or increased deference to community control of new housing (hyperlocalism). I test each of these theories using a survey experiment, including both attitudinal scales and conjoint analysis. Doing so, I find no evidence that liberals are less supportive of new housing nor show greater deference to com- munity control of housing decisions. In contrast, I find increased NIMBYism among conservatives, particularly in high-income, low density environments. Together, these findings suggest that the political geography concepts of spatial proximity and control over spatially-based policy are not the primary drivers of the housing supply shortage in liberal cities. {${_\ast}$}PhD},
	author = {Hankinson, Michael},
	file = {/Users/wpmarble/Zotero/storage/EUQW38TJ/2015-The_Landscape_Political_Interacting_Ideology_with_Spatial_Proximity_and_Control_via_New_Housing.pdf},
