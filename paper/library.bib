	journal = {Journal of Urban Economics},
	keywords = {capitalization,Capitalization,education,Elderly,Land supply,land use,local politics,School spending},
	number = {1},
	pages = {74--90},
	pmid = {703430},
	publisher = {{Elsevier Inc.}},
	title = {Why Do Households without Children Support Local Public Schools? {{Linking}} House Price Capitalization to School Spending},
	volume = {65},
