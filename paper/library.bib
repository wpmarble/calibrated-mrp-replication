	keywords = {political behavior,political engagement},
	number = {2},
	pages = {371--390},
	title = {Democracy, {{Institutions}} and {{Attitudes}} about {{Citizen Influence}} on {{Government}}},
	volume = {32},
	year = {2002},
	bdsk-url-1 = {https://doi.org/10.1017/S0007123402000157}}

@article{Bowles2002,
	abstract = {Community governance is the set of small group social interactions that, with market and state, determine economic outcomes. We argue (i) community governance addresses some common market and state failures but typically relies on insider-outsider distinctions that may be morally repugnant and economically costly; (ii) the individual motivations supporting community gov- ernance are not captured by either selfishness or altruism; (iii) communities, markets and states are complements, not substitutes; (iv) when poorly designed, markets and states crowd olut communities; (v) some distributions of property rights are better than others at fostering com- munity governance; and (vi) communities will probably increase in importance in the future.},
