@techreport{Cox2015,
	abstract = {Why do developing countries fail to adopt the institutions and policies that promote development? Our answer is the violence trap. Key political reforms\textemdash opening access and reducing rents\textemdash are typically feasible only when the domestic economy reaches a given level of complexity (for reasons we specify); yet complex economies typically can emerge only when key political reforms are already in place (for standard reasons). The interdependence of political reform and economic complexity entails violence because, as we show, unreformed polities lack adaptive efficiency. The literature sparked by Lipset's modernization thesis has operationalized ``economic development'' as a higher GDP per capita. Building on Steuart, we view development as creating a more complex economy whose workings will be more seriously disrupted by political violence. Empirically, we show that economic complexity (as measured by the Hidalgo-Hausmann index) strongly deters coups, even controlling for GDP per capita and level of democracy},
	author = {Cox, Gary W. and North, Douglass C. and Weingast, Barry R.},
	doi = {10.2139/ssrn.2370622},
	file = {/Users/wpmarble/Zotero/storage/G5RT2UQ6/m-api-69e111bb-5d2a-38dd-5cd5-be60c95c0009.pdf},
	issn = {1556-5068},
	keywords = {comparative political institutions,institutions,political economy,political violence},
	pages = {1--35},
	title = {The {{Violence Trap}}: {{A Political-Economic Approach}} to the {{Problems}} of {{Development}}},
	year = {2015},
	bdsk-url-1 = {https://doi.org/10.2139/ssrn.2370622}}

@article{Cox2015a,
	abstract = {This essay reviews models of strategic mobilization and turnout, focusing on two important questions about the effects of electoral rules. First, how does the disproportionality of the electoral system affect the variance and mean of mobilization and turnout? This question has been investigated at least since Gosnell (1930) . In addition to reviewing the literature, I argue that extant models should pay more explicit attention to secondary mobilization (conducted by interest groups, activists, and ordinary voters). Second, how do electoral rules regulating the electoral calendar and vote fusion affect mobilizational spillovers and, hence, incentives to build mobilizational alliances? This question has attracted less attention from modelers but is well represented in the empirical literature.},
