	issn = {09641998},
	journal = {Journal of the Royal Statistical Society: Series A (Statistics in Society)},
	keywords = {censored data,Censored data,census data,Current Population Survey,Generalized beta of the second kind distribution,Income inequality,inequality,methods,missing data,multiple imputation,Multiple imputation,Top coding},
	number = {1},
