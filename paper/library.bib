@article{Rogers1988,
	abstract = {Most social scientists would agree that the capacipfor human culture wasprobably fashioned by natural selection, but they disagree about the implications of this supposition. Some believe that natural selection imposes important constraints on the ways in which culture can vary, while others believe that any such constraints must be negligible. This article emplcys a ``thought experi- ment'' to demonstrate that neither of these positions can be justijed by appeal to general prop- erties of culture or of evolution. Natural selection can produce mechanisms of cultural transmission thal are neither adaptive nor consistent with the predictions of acultural evolutionary models (those ignoring cultural evolution). On the other hand, natural selection can also produce mechanisms of cultural transmission that are highb consistent with acultural models. Thus, neither side of the sociobiology debate is justified in dismissing the arguments of the other. Natural selection may impose signijicant constraints on some human behaviors, but negligible constraints on others. Models of simultaneous geneticlcultural evolution will be usehl in identifying domains in which acultural evolutionary models are, and are not, likely to be use@. T},
	author = {Rogers, Alan R.},
	journal = {American Anthropologist},
	keywords = {anthropology,biology,culture,political culture},
	pages = {819--831},
	title = {Does {{Biology Constraint Culture}}?},
	volume = {90},
	year = {1988}}

@article{Rogers2014,
	abstract = {Public opinion researchers, campaigns, and political scientists often rely on self-predicted vote to forecast turnout, allocate resources, and measure political engagement. Despite its importance, little research has examined the accuracy of self-predicted vote responses. Seven pre-election surveys with postelection vote validation from three elections (N = 29,403) reveal several patterns. First, many self-predicted voters do not actually vote (flake-out). Second, many self-predicted nonvoters do actually vote (flake-in). This is the first robust observation of flake-in. Third, actual voting is more accurately predicted by past voting (from voter file or recalled) than by self-predicted voting. Finally, self-predicted voters differ from actual voters demographically. Actual voters are more likely to be White (and not Black), older, and partisan than actual nonvoters (i.e., there is participatory bias), but self-predicted voters and self-predicted nonvoters do not differ much. Vote self-prediction is "biased" in that it misleadingly suggests that there is no participatory bias. \textcopyright{} The Author(s) 2013.},
	author = {Rogers, Todd and Aida, Masahiko},
	doi = {10.1177/1532673X13496453},
	file = {/Users/wpmarble/Zotero/storage/ART46CYR/Rogers, Aida - 2014 - Vote Self-Prediction Hardly Predicts Who Will Vote, and Is (Misleadingly) Unbiased.pdf},
	issn = {15523373},
	journal = {American Politics Research},
	keywords = {forecasting,likely voter model,participatory bias,political behavior,polling,polls,public opinion,survey,turnout},
	number = {3},
	pages = {503--528},
	title = {Vote {{Self-Prediction Hardly Predicts Who Will Vote}}, and {{Is}} ({{Misleadingly}}) {{Unbiased}}},
	volume = {42},
	year = {2014},
	bdsk-url-1 = {https://doi.org/10.1177/1532673X13496453}}

@article{Rogowski2021,
	abstract = {The liberal international order (LIO) has reduced inequality between societies but increased it within them, likely contributing to ``populist'' movements' growing rejection of the LIO. Standard theories explain how openness has widened the income gap between high- and low-skill workers and motivated the latter to oppose globalization; but not why the top stratum has gained disproportionately, populists focus their ire on elites, or many within high-skill groups support populism. An ``enriched'' Heckscher-Ohlin model offers crucial insights, and European voting data show that shocks from trade and migration elicit populist opposition only where the top 1 per cent have gained most. High inequality leads also to slower economic growth and deeper conflict within and among states, but research so far finds little political support for effective policies to reduce it. Inequality, populism, polarization, and conflict all seem likely to increase, at least over the near term.},
	author = {Rogowski, Ron and Flaherty, Thomas},
	doi = {10.1017/S0020818321000163},
	file = {/Users/wpmarble/Zotero/storage/GWGU9YIK/Rogowski, Flaherty - 2021 - Rising Inequality as a Threat to the Liberal International Order.pdf},
	journal = {International Organization},
	keywords = {globalization,international political economy,international relations,liberalism,populism,trade},
	title = {Rising {{Inequality}} as a {{Threat}} to the {{Liberal International Order}}},
