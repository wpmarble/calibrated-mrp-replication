	file = {/Users/wpmarble/Zotero/storage/IA4QBSRF/Ballard-Rosa, Scheve, Jensen - 2021 - Economic Decline, Social Identity, and Authoritarian Values in the United States(2).pdf},
	journal = {International Studies Quarterly},
	keywords = {authoritarianism,china,economic voting,globalization,identity,voting},
	title = {Economic {{Decline}}, {{Social Identity}}, and {{Authoritarian Values}} in the {{United States}}},
