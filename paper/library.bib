@article{Grimmer2013,
	abstract = {Congressional districts create two levels of representation. Studies of representation focus on a disaggregated level: the electoral connection between representatives and constituents. But there is a collective level of representation\textemdash the result of aggregating across representatives. This article uses new measures of home styles to demonstrate that responsiveness to constituents can have negative consequences for collective representation. The electoral connection causes marginal representatives\textemdash legislators with districts composed of the other party's partisans\textemdash to emphasize appropriations in their home styles. But it causes aligned representatives\textemdash those with districts filled with copartisans\textemdash to build their home styles around position taking. Aggregated across representatives, this results in an artificial polarization in stated party positions: aligned representatives, who tend to be ideologically extreme, dominate policy debates. The logic and evidence in this article provide an explanation for the apparent rise in vitriolic debate, and the new measures facilitate a literature on home styles.},
	author = {Grimmer, Justin},
	doi = {10.1111/ajps.12000},
	file = {/Users/wpmarble/Zotero/storage/3H3EKSG5/2013-Appropriators_not_Position_Takers_The_Distorting_Effects_of_Electoral_Incentives_on_Congressional_Representation.pdf},
	isbn = {1540-5907},
	issn = {00925853},
	journal = {American Journal of Political Science},
	keywords = {congress,home style,position taking,representation},
