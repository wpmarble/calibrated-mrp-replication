@techreport{bonomiIdentityBeliefsPolitical2020,
	abstract = {We present a theory of identity politics that builds on two ideas. First, when policy con\textdaggerdbl ict renders a certain social divide (economic of cultural) salient, a voter's beliefs are tainted by the stereotype of the group he identi\ldots es with. Second, culture in\textdaggerdbl uences beliefs across many domains. The theory yields two main implications: i) voters'beliefs are polarized along the distinctive features of salient groups; ii) cultural change and spe- ci\ldots c economic shocks can render cultural groups salient, inducing large and non standard changes in beliefs and policies. In particular, shocks concentrating economic losses on social conservative groups (e.g., globalization) can induce voters to switch from class to cultural identity, dampening their demand for redistribution and exacerbating con\textdaggerdbl ict in other social dimensions. We show that U.S. survey evidence is broadly consistent with these implications. ?We},
	author = {Bonomi, Giampaolo and Gennaioli, Nicola and Tabellini, Guido},
	file = {/Users/wpmarble/Zotero/storage/NUWR9CTL/Bonomi, Gennaioli, Tabellini - 2020 - Identity Beliefs, and Political Conflict.pdf},
	keywords = {culture,economic geography,identity,political culture,social issues},
	title = {Identity {{Beliefs}}, and {{Political Conflict}}},
