@techreport{Sekhon2004,
	abstract = {Using new robust matching methods for making causal inferences from survey data, I demon- strate that there are profound differences between how voters behave in advanced democra- cies versus how they behave in new electoral democracies. The problems of voter ignorance and inattentiveness are not as serious in advanced democracies as many analysts have sug- gested but are of grave concern in new democracies. Citizens in advanced democracies are able to accomplish something that citizens in fledgling democracies are not: inattentive and poorly informed citizens are able to vote like their better informed compatriots and hence need to pay little attention to political events such as election campaigns in order to vote as if they were attentive. The results from the U.S. (which rely on various National Election Studies) and Mexico (2000 Panel Study) are reported in detail. Results from other countries are briefly reported.},
	author = {Sekhon, Jasjeet S.},
