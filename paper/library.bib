	volume = {91},
	year = {2010}}

@article{Rubin1991,
	abstract = {Zoning restrictions, combined with rapid appreciation of house prices\textbackslash nand high real mortgage rates, have constrained the supply of affordable\textbackslash nhousing; see Rosen [19]. Recent reductions in federal housing support\textbackslash nand a dissatisfaction with the amount and location of housing made\textbackslash navailable through filtering have led to a growing reliance on an\textbackslash nexactions approach to affordable housing; see Gutis [7] and Smith\textbackslash n[22]. For example, in Montgomery County, Maryland, builders must\textbackslash nprovide 12\% of any new housing development (over 49 units) for low-\textbackslash nand moderate-income households (Stevens [25]). The California Coastal\textbackslash nCommission requires a 25\% dedication in its jurisdiction; in Palo\textbackslash nAlto, California builders must set aside lo\%, while Orange County,\textbackslash nCalifornia has a sliding requirement based on income. Perhaps the\textbackslash nmost ambitious program is New Jersey\dbend s legislation which encourages\textbackslash neach of its 567 municipalities to provide affordable housing; see\textbackslash nBurchell et al. [l], Rose [18], and Chall [2].},
