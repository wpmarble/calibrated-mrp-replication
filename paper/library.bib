@article{Diermeier2018,
	abstract = {We examine the interaction between partisan affect and elite polarization in a be- havioral voting model. Voting is determined by affect rather than rational choice. Parties are office-motivated; they choose policies to win elections. We show that par- ties bias their policies toward their partisans if voters exhibit ingroup responsiveness, i.e., they respond more strongly to their own party's policy deviations than to pol- icy deviations by the other party. Our results suggest that affective polarization is a driver of the growing elite polarization in American politics. Importantly, this obser- vation does not assume any shifts in the voters' bliss points and is therefore free of the controversy over whether the American electorate has become more polarized in ideology},
