@book{Krehbiel1991,
	abstract = {Krehbiel proposes the informational theory of legislative organization in contrast to the distributive theory. The underlying principles are the majoritarian principle, in which "objects of legislative choice in both the procedural and policy domains must be chosen by a majority of the legislature", and the uncertainty principle, which states that "legislators are often uncertain about the relationships between policies and their outcomes." Both distributive and informational approaches rely on the majoritarian principle, but the distributive theory takes institutional arrangements as given as oposed to being put in place by a majority of the legislature. More central to the informational theory is the concept that legislators are uncertain about outcomes of policies, and thus it is in their interest to induce specializaiton and then incorporate rules that minimize the possibility of particularistic benefits or shirking of institutional maintenance. Much of the uncertainty approach is couched in signalling theory, which predicts much of the behavior that the parent chamber vis-a-vis the committee characteristics and actions. One sentence: committees decrease the members level of uncertainty about outcomes.},
	address = {{Ann Arbor, Michigan}},
	author = {Krehbiel, Keith},
