	journal = {Journal of Economic Perspectives},
	keywords = {and Other Normative Criteria and Measurement,and Their Distributions,D31,D63,D72,Elections Legislatures and Voting Behavior,Environmental Taxes and Subsidies,Equity,H23,income distribution,income inequality,inequality,Inequality,Justice,Lobbying,Personal Income,polarization,Political Processes: Rent-seeking,Redistributive Effects,representation,Taxation and Subsidies: Externalities,Wealth},
