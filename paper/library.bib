@techreport{BuenoDeMesquita2019,
	abstract = {We pose the commensurability problem: when do estimates generated by actual research designs correspond to quantities of theoretical interest in ideal experiments? We study this question in settings where both treatment and outcome are behavior and the treatment effect of interest is decomposable into direct and informational channels. We establish two results. First, the quantity estimated by an actual research design is only commensurate with the total effect in the ideal experiment if treatment status in the research design is a sufficient statistic for the decision-makers' information in the ideal experiment. Second, a research design corresponding to a non-ideal experiment isolates just the direct effect in the ideal experiment if two conditions hold: (i) there is no information effect in the non-ideal experiment and (ii) the decision-maker's response function is additively separable in treatment and information. We apply our results to three substantive literatures: the efficacy of protest, the empowerment of female candidates, and indiscriminate violence in counterinsurgency.},
	author = {Bueno De Mesquita, Ethan and Tyson, Scott A.},
	file = {/Users/wpmarble/Zotero/storage/DVY5FMAV/Bueno De Mesquita, Tyson - 2019 - The Commensurability Problem Conceptual Difficulties in Estimating the Effect of Behavior on Behavior.pdf},
	keywords = {formal model,information,methods,natural experiment},
	title = {The {{Commensurability Problem}}: {{Conceptual Difficulties}} in {{Estimating}} the {{Effect}} of {{Behavior}} on {{Behavior}}},
