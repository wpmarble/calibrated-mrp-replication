@article{Hopkins2009,
	abstract = {According to recent research, racial and ethnic diversity reduces U.S. localities' investment in public goods. Yet we remain unsure about the mechanisms behind that relationship and uncertain that the relationship is causal. This essay addresses these challenges by studying the impact of racial and ethnic demographics on property tax votes in Massachusetts and Texas. Employing novel time-series cross-sectional data, it departs from the emerging consensus by showing that diversity does not always influence local tax votes. Instead, diversity reduces localities' willingness to raise taxes only when localities are undergoing sudden demographic changes. Theoretically, this finding points us away from the dominant understanding of diversity as divergent preferences, and towards approaches that emphasize how sudden demographic changes can destabilize residents' expectations and influence local elites. To understand how diversity influences public good provision, we should look to those towns that are diversifying, not those towns that are diverse.},
	author = {Hopkins, Daniel J.},
	doi = {10.1017/S0022381608090105},
	file = {/Users/wpmarble/Zotero/storage/XMVYL8UV/Hopkins - The Diversity Discount.pdf},
	issn = {0022-3816},
	journal = {Journal of Politics},
	keywords = {ethnic diversity,public goods provision,redistribution,taxation,welfare},
	number = {1},
	pages = {160--177},
	title = {The {{Diversity Discount}}: {{When Increasing Ethnic}} and {{Racial Diversity Prevents Tax Increases}}},
	volume = {71},
	year = {2009},
	bdsk-url-1 = {https://doi.org/10.1017/S0022381608090105}}

@article{Hopkins2012,
	abstract = {Perceptions of economic performance are a cornerstone of American public opinion, and are strongly correlated with Presidential approval. Yet much of our knowledge about economic perceptions comes from political surveys conducted in the 1970s and 1980s. Past evidence has limited over-time variation, much of it predating the recent increase in income inequality. This paper updates our understanding of economic perceptions by combining the 1978-2003 Michigan Surveys of Consumer Attitudes with various economic indicators. Snapshots from elections create the impression that Americans' assessments of economic performance are influenced only by income growth among the wealthy. Examining 185,000 respondents to a monthly survey over 26 years, however, we learn that income growth among the poor is frequently more influential, especially among those with lower incomes themselves. Echoing findings of a ``rational public,'' Americans' aggregate economic assessments appear to be grounded in the economic conditions relevant to their levels of income.},
	author = {Hopkins, Daniel J.},
	doi = {10.1093/poq/nfr039},
	file = {/Users/wpmarble/Zotero/storage/AF9B7FIB/2012-Whose_economy_Perceptions_of_national_economic_performance_during_unequal_growth.pdf},
