	file = {/Users/wpmarble/Zotero/storage/DERLSATV/McLaughlin et al. - 2012 - Home foreclosure and risk of psychiatric morbidity during the recent financial crisis.pdf},
	isbn = {0033-2917},
	issn = {00332917},
	journal = {Psychological Medicine},
	keywords = {anxiety,Anxiety,depression,financial crisis,foreclosure,housing,mental health,stress},
