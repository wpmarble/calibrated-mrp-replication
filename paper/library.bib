@article{Caughey2016,
	abstract = {Social scientists are commonly advised to deduce and test all observable implications of their theories. We describe a principled framework for testing such ``elaborate'' theories: nonparametric combination. NPC assesses the joint probability of observing the theoretically predicted pattern of results under the sharp null of no effects. NPC accounts for the dependence among the component tests without relying on model- ing assumptions or asymptotic approximations. Multiple-testing corrections are also easily implemented with NPC. As we demonstrate with four applications, NPC lever- ages theoretical knowledge into greater statistical power, which is particularly valuable for studies with strong research designs but small sample sizes. We implement these methods in a new R package, NPC},
	author = {Caughey, Devin and Dafoe, Allan and Seawright, Jason},
	file = {/Users/wpmarble/Zotero/storage/9IDQMZHL/2016-Nonparametric_Combination_(NPC)_A_Framework_for_Testing_Elaborate_Theories.pdf},
