@article{Ramasubramanian2011,
	abstract = {This study examines how exposure to media characters of color shapes viewers' opinions of race-targeted policies. Exemplar-based information processing, attribution theory, and heuristic policy decision-making formed the theoretical foundation for the study. A 2 \texttimes{} 2 factorial experiment (N = 363) exposed participants to stereotypical or counterstereotypical exemplars representing the in-group (Whites) and the out-group (Blacks). The experiment revealed that exposure to stereotypical African American media characters compared to exposure to counter-stereotypical ones influenced real-world beliefs of African American stereotypes, internal attributions for perceived failures of this out-group, prejudicial feelings toward this out-group, and lack of support for pro-minority affirmative action policies. A structural model established "internal attributions for out-group failures" as a crucial mediator. Implications for entertainment studies and political communication are discussed. \textcopyright{} The Author(s) 2011.},
