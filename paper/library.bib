@incollection{Chetty2011,
	abstract = {We survey the literature on social insurance, focusing on recent work that has connected theory to evidence to make quantitative statements about welfare and optimal policy. Our review contains two parts. We \ldots rst discuss motives for government intervention in private insurance markets, focusing primarily on selection. We review the original theoretical arguments for government intervention in the presence of adverse selection, and describe how recent work has re\ldots ned and challenged the conclusions drawn from early theoretical models. We then describe empirical work that tests for selection in insurance markets, documents the welfare costs of this selection, and analyzes the welfare consequences of potential public policy interventions. In the second part of the paper, we review work on optimal social insurance policies. We discuss formulas for the optimal level of insurance bene\ldots ts in terms of empirically estimable parameters. We then consider the consequences of relaxing the key assumptions underlying these formulas, e.g., by allowing for \ldots scal externalities or behavioral biases. We also summarize recent work on other dimensions of optimal policy, including mandated savings accounts and the optimal path of bene\ldots ts. Finally, we discuss the key challenges that remain in understanding the optimal design of social insurance policies. ?We},
	author = {Chetty, Raj and Finkelstein, Amy},
	booktitle = {Handbook of {{Public Economics}}},
	file = {/Users/wpmarble/Zotero/storage/FL9P7UND/Chetty, Finkelstein - 2011 - Social Insurance Connecting Theory to Data.pdf},
