@article{Hainmueller2010,
	abstract = {Past research has emphasized two critical economic concerns that appear\textbackslash nto generate anti-immigrant sentiment among native citizens: concerns\textbackslash nabout labor market competition and concerns about the fiscal burden\textbackslash non public services. We provide direct tests of both models of attitude\textbackslash nformation using an original survey experiment embedded in a nationwide\textbackslash nU.S. survey. The labor market competition model predicts that natives\textbackslash nwill be most opposed to immigrants who have skill levels similar\textbackslash nto their own. We find instead that both low-skilled and highly skilled\textbackslash nnatives strongly prefer highly skilled immigrants over low-skilled\textbackslash nimmigrants, and this preference is not decreasing in natives' skill\textbackslash nlevels. The fiscal burden model anticipates that rich natives oppose\textbackslash nlow-skilled immigration more than poor natives, and that this gap\textbackslash nis larger in states with greater fiscal exposure (in terms of immigrant\textbackslash naccess to public services). We find instead that rich and poor natives\textbackslash nare equally opposed to low-skilled immigration in general. In states\textbackslash nwith high fiscal exposure, poor (rich) natives are more (less) opposed\textbackslash nto low-skilled immigration than they are elsewhere. This indicates\textbackslash nthat concerns among poor natives about constraints on welfare benefits\textbackslash nas a result of immigration are more relevant than concerns among\textbackslash nthe rich about increased taxes. Overall the results suggest that\textbackslash neconomic self-interest, at least as currently theorized, does not\textbackslash nexplain voter attitudes toward immigration. The results are consistent\textbackslash nwith alternative arguments emphasizing noneconomic concerns associated\textbackslash nwith ethnocentrism or sociotropic considerations about how the local\textbackslash neconomy as a whole may be affected by immigration.},
