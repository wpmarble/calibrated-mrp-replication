@techreport{Gulzar2017,
	abstract = {Abstract How do individual and social benefits of becoming a politician shape one's de- cision to run for office, election prospects, and in-office performance? In a field experiment before elections for new village councils in Pakistan, we make salient personal benefits of political office \textendash{} such as gaining respect and status \textendash{} or social benefits \textendash{} such as the ability to help others. We do this by making these appeals to a random sample of citizens in one-on-one private meetings and in village- level public meetings. First, we find that making any appeal to run increases the probability of candidacy five-fold. Second, the two benefits have no effect on candidacy in private but opposite and large effects in public: social benefits boost candidacy, while personal benefits suppress it. Finally, highlighting social bene- fits in public also affects performance of elected politicians \textendash{} their performance is more aligned with citizen preferences.},
	author = {Gulzar, Saad and Khan, M.},
