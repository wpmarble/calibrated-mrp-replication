@article{A:1978,
	abstract = {The statistical study of representation has depended largely on correlational meas- ures, which have little substantive content and can be misleading in their implications. In their place, three measures of representativeness are offered, reflecting the liberal democratic concepts of citizen equality, neutrality toward alternatives, and popular sovereignty. These measures are applied to the Miller-Stokes data on American Congressmen. The findings revise Miller and Stokes' conclusions in two respects: (1) winners are less representative than losers on two of the three measures, and (2) all issue dimensions are approximately equally well represented, with civil rights views having no special advantage.},
	author = {Achen, Christopher H.},
